@import 'tailwindcss';
@import 'tw-animate-css';
@import 'shadcn/tailwind.css';

@custom-variant dark (&:is(.dark *));

@theme inline {
  --font-heading: var(--font-sans);
  --font-sans: var(--font-inter), 'Inter Fallback', sans-serif;
  --font-mono: var(--font-geist-mono), 'Geist Mono Fallback';

  --color-ring: var(--ring);
  --color-input: var(--input);
  --color-border: var(--border);
  --color-destructive: var(--destructive);
  --color-destructive-foreground: var(--destructive-foreground);
  --color-danger: var(--danger);
  --color-danger-foreground: var(--danger-foreground);
  --color-warning: var(--warning);
  --color-warning-foreground: var(--warning-foreground);
  --color-success: var(--success);
  --color-success-foreground: var(--success-foreground);
  --color-info: var(--info);
  --color-info-foreground: var(--info-foreground);
  --color-accent-foreground: var(--accent-foreground);
  --color-accent: var(--accent);
  --color-muted-foreground: var(--muted-foreground);
  --color-muted: var(--muted);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-secondary: var(--secondary);
  --color-primary-foreground: var(--primary-foreground);
  --color-primary: var(--primary);
  --color-popover-foreground: var(--popover-foreground);
  --color-popover: var(--popover);
  --color-card-foreground: var(--card-foreground);
  --color-card: var(--card);
  --color-foreground: var(--foreground);
  --color-background: var(--background);
  --color-surface: var(--surface);
  --color-surface-muted: var(--surface-muted);
  --color-brand: var(--brand);
  --color-brand-foreground: var(--brand-foreground);
  --color-brand-accent: var(--brand-accent);
  --color-sidebar: var(--sidebar);
  --color-sidebar-foreground: var(--sidebar-foreground);
  --color-sidebar-hover: var(--sidebar-hover);
  --color-sidebar-active: var(--sidebar-active);
  --color-sidebar-active-foreground: var(--sidebar-active-foreground);
  --color-sidebar-border: var(--sidebar-border);

  --radius-xs: calc(var(--radius) * 0.2);
  --radius-sm: calc(var(--radius) * 0.4);
  --radius-md: var(--radius);
  --radius-lg: calc(var(--radius) * 1.5);
  --radius-xl: calc(var(--radius) * 1.75);
  --radius-2xl: calc(var(--radius) * 2);
  --radius-3xl: calc(var(--radius) * 2.5);

  --shadow-xs: 0 1px 2px rgba(31, 42, 109, 0.05);
  --shadow-sm: 0 4px 12px rgba(31, 42, 109, 0.06);
  --shadow-md: 0 10px 28px rgba(31, 42, 109, 0.1);
  --shadow-lg: 0 18px 48px rgba(31, 42, 109, 0.14);
  --shadow-xl: 0 24px 70px rgba(31, 42, 109, 0.18);
}

:root {
  --radius: 0.5rem;

  --background: hsl(210 40% 98%);
  --foreground: hsl(222 47% 11%);
  --card: var(--surface);
  --card-foreground: var(--foreground);
  --popover: var(--surface);
  --popover-foreground: var(--foreground);
  --surface: hsl(0 0% 100%);
  --surface-muted: hsl(210 20% 96%);

  --primary: hsl(221 83% 53%);
  --primary-foreground: hsl(0 0% 100%);
  --secondary: var(--surface-muted);
  --secondary-foreground: var(--foreground);
  --muted: var(--surface-muted);
  --muted-foreground: hsl(215 20% 45%);
  --accent: var(--surface-muted);
  --accent-foreground: var(--foreground);

  --sidebar: var(--surface);
  --sidebar-foreground: var(--foreground);
  --sidebar-hover: var(--surface-muted);
  --sidebar-active: color-mix(in srgb, var(--primary) 10%, white);
  --sidebar-active-foreground: var(--primary);
  --sidebar-border: var(--border);

  --success: hsl(142 71% 45%);
  --success-foreground: hsl(0 0% 100%);
  --warning: hsl(38 92% 50%);
  --warning-foreground: hsl(0 0% 100%);
  --danger: hsl(0 84% 60%);
  --danger-foreground: hsl(0 0% 100%);
  --destructive: var(--danger);
  --destructive-foreground: var(--danger-foreground);

  --border: hsl(214 32% 91%);
  --input: hsl(214 32% 91%);
  --ring: var(--primary);

  --brand: var(--primary);
  --brand-foreground: var(--primary-foreground);
  --brand-accent: var(--primary);
  --info: var(--primary);
  --info-foreground: var(--primary-foreground);
}

.dark {
  --background: hsl(222 47% 4%);
  --foreground: hsl(210 40% 98%);
  --card: hsl(222 47% 7%);
  --card-foreground: var(--foreground);
  --popover: hsl(222 47% 7%);
  --popover-foreground: var(--foreground);
  --surface: hsl(222 47% 7%);
  --surface-muted: hsl(217 33% 10%);

  --primary: hsl(221 83% 62%);
  --primary-foreground: hsl(0 0% 100%);
  --secondary: var(--surface-muted);
  --secondary-foreground: var(--foreground);
  --muted: var(--surface-muted);
  --muted-foreground: hsl(215 20% 70%);
  --accent: var(--surface-muted);
  --accent-foreground: var(--foreground);

  --success: hsl(142 71% 50%);
  --success-foreground: hsl(0 0% 100%);
  --warning: hsl(38 92% 58%);
  --warning-foreground: hsl(0 0% 100%);
  --danger: hsl(0 84% 66%);
  --danger-foreground: hsl(0 0% 100%);
  --destructive: var(--danger);
  --destructive-foreground: var(--danger-foreground);

  --border: hsl(215 28% 17%);
  --input: hsl(215 28% 17%);
  --ring: var(--primary);

  --brand: var(--primary);
  --brand-foreground: var(--primary-foreground);
  --brand-accent: var(--primary);
  --info: var(--primary);
  --info-foreground: var(--primary-foreground);

  --sidebar: hsl(222 47% 7%);
  --sidebar-foreground: hsl(210 40% 98%);
  --sidebar-hover: hsl(217 33% 12%);
  --sidebar-active: color-mix(in srgb, var(--primary) 15%, var(--surface));
  --sidebar-active-foreground: var(--primary);
  --sidebar-border: var(--border);
}

@layer base {
  * {
    @apply border-border outline-ring/50;
  }
  html,
  body {
    height: 100%;
    overflow: hidden;
  }
  body {
    @apply bg-background text-foreground;
  }
  html {
    @apply font-sans bg-background;
  }
}

@layer components {
  .g2g-page-scroll {
    overflow-y: auto;
    overflow-x: hidden;
  }

  .g2g-scrollbar {
    scrollbar-width: thin;
    scrollbar-color: color-mix(in srgb, var(--muted-foreground) 35%, transparent) transparent;
  }
  .g2g-scrollbar::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }
  .g2g-scrollbar::-webkit-scrollbar-thumb {
    background-color: color-mix(in srgb, var(--muted-foreground) 35%, transparent);
    border-radius: 9999px;
    border: 3px solid transparent;
    background-clip: content-box;
  }
  .g2g-scrollbar::-webkit-scrollbar-thumb:hover {
    background-color: color-mix(in srgb, var(--muted-foreground) 45%, transparent);
  }
}
